#: addon\globalPlugins\BMI\bmiCalculator.py:37
msgid "Height and weight must be greater than zero."
msgstr "A altura e o peso devem ser maiores que zero."

#. translator: Label for height input field
#: addon\globalPlugins\BMI\main.py:60
msgid "Enter or select your height in centimeters:"
msgstr "Digite ou selecione sua altura em centímetro:"

#. translator: Label for weight input field
#: addon\globalPlugins\BMI\main.py:67
msgid "Enter or select your weight in kilograms:"
msgstr "Digite ou selecione seu peso em quilogramas:"

#: addon\globalPlugins\BMI\main.py:73
msgid "C&alculate"
msgstr "C&alcular"

#: addon\globalPlugins\BMI\main.py:78
msgid "C&lear"
msgstr "&Limpar"

#: addon\globalPlugins\BMI\main.py:83
msgid "&History"
msgstr "&Histórico"

#: addon\globalPlugins\BMI\main.py:88
msgid "&Cancel"
msgstr "&Cancelar"

#: addon\globalPlugins\BMI\main.py:104 addon\globalPlugins\BMI\main.py:114
#: addon\globalPlugins\BMI\main.py:155
msgid "Attention"
msgstr "Atenção"

#. translator: Error message when BMI calculation fails
#: addon\globalPlugins\BMI\main.py:113
msgid "Unable to calculate BMI. Please check the values."
msgstr "Não foi possível calcular o IMC. Verifique os valores."

#: addon\globalPlugins\BMI\main.py:123
msgid "Ideal weight range for your height: {} kg to {} kg."
msgstr "Faixa de peso ideal para sua altura: {} kg a {} kg."

#: addon\globalPlugins\BMI\main.py:127
msgid ""
"Observation:\n"
"\n"
"For an accurate interpretation of BMI, it is important to consider other "
"factors such as body composition, fat distribution, age, gender, and overall "
"health.\n"
"It is always recommended to consult a healthcare professional for proper "
"guidance on health and weight."
msgstr ""
"Observação:\n"
"\n"
"Para uma interpretação precisa do IMC, é importante levar em conta outros "
"fatores, como a composição corporal, a distribuição de gordura, a idade, o "
"sexo e o estado geral de saúde.\n"
"Recomenda-se sempre consultar um profissional de saúde para obter "
"orientações adequadas sobre saúde e peso."

#: addon\globalPlugins\BMI\main.py:135
msgid ""
"Your BMI is {}.\n"
"\n"
"You are underweight.\n"
"\n"
"It is important to consult a doctor or nutritionist to identify healthy ways "
"to gain weight.\n"
"\n"
"{}\n"
"\n"
"{}"
msgstr ""
"Seu IMC é {}.\n"
"\n"
"Você está abaixo do peso.\n"
"\n"
"É importante consultar um médico ou nutricionista para identificar maneiras "
"saudáveis de ganhar peso.\n"
"\n"
"{}\n"
"\n"
"{}"

#: addon\globalPlugins\BMI\main.py:139
msgid ""
"Your BMI is {}.\n"
"\n"
"You are at a healthy weight.\n"
"\n"
"Maintain it with a balanced diet and regular physical activity.\n"
"\n"
"{}\n"
"\n"
"{}"
msgstr ""
"Seu IMC é {}.\n"
"\n"
"Você está com um peso saudável.\n"
"\n"
"Mantenha-o com uma dieta balanceada e atividade física regular.\n"
"\n"
"{}\n"
"\n"
"{}"

#: addon\globalPlugins\BMI\main.py:143
msgid ""
"Your BMI is {}.\n"
"\n"
"You are overweight.\n"
"\n"
"It is important to consult a doctor or nutritionist to identify healthy "
"weight loss strategies.\n"
"\n"
"{}\n"
"\n"
"{}"
msgstr ""
"Seu IMC é {}.\n"
"\n"
"Você está acima do peso.\n"
"\n"
"É importante consultar um médico ou nutricionista para identificar "
"estratégias saudáveis de perda de peso.\n"
"\n"
"{}\n"
"\n"
"{}"

#: addon\globalPlugins\BMI\main.py:147
msgid ""
"Your BMI is {}.\n"
"\n"
"You are significantly overweight.\n"
"\n"
"Please consult a healthcare provider for guidance.\n"
"\n"
"{}\n"
"\n"
"{}"
msgstr ""
"Seu IMC é {}.\n"
"\n"
"Você está significativamente acima do peso.\n"
"\n"
"Consulte um profissional de saúde para obter orientação.\n"
"\n"
"{}\n"
"\n"
"{}"

#: addon\globalPlugins\BMI\main.py:151
msgid ""
"Your BMI is {}.\n"
"\n"
"Your BMI indicates that you are in the obese range.\n"
"\n"
"It is important to consult a doctor to reduce health risks through safe "
"weight loss.\n"
"\n"
"{}\n"
"\n"
"{}"
msgstr ""
"Seu IMC é {}.\n"
"\n"
"Seu IMC indica que você está na faixa de obesidade.\n"
"\n"
"É importante consultar um médico para reduzir os riscos à saúde por meio de "
"uma perda de peso segura.\n"
"\n"
"{}\n"
"\n"
"{}"

